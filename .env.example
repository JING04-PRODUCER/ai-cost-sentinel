# ===== 上游 LLM API 配置 =====
# 你要代理的目标 API 地址
UPSTREAM_BASE_URL=https://api.openai.com/v1
# 目标 API 的密钥（如果目标本身需要鉴权）
UPSTREAM_API_KEY=sk-your-api-key-here
# 代理请求超时（秒）
UPSTREAM_TIMEOUT=120

# ===== 管理鉴权 =====
# 访问 /sentinel/* 管理端点所需的 Bearer Token（为空则不鉴权）
SENTINEL_ADMIN_TOKEN=

# ===== 预算控制 =====
# notify_only: 仅通知不拦截 / reject: 超预算直接拒绝请求
SENTINEL_BUDGET_MODE=notify_only

# ===== Webhook 通知（可选）=====
SENTINEL_WEBHOOK_URL=
